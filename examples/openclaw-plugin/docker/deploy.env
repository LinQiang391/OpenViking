################################################################################
# OpenClaw + OpenViking + openGauss 一键部署配置文件
#
# 使用说明:
#   1. 根据实际环境修改下方「必填」标注的配置项
#   2. 被 # 注释掉的变量为可选项，取消注释即可启用
#   3. 部署:
#        bash deploy.sh -password <openGauss密码>
#      仅部署 OpenViking + OpenClaw (不启动 openGauss):
#        bash deploy.sh
#
#   openGauss 数据库密码出于安全考虑不在此文件中配置，
#   部署时通过 -password 参数传入。
################################################################################

# ==============================================================================
# [必填] 是否启动 openGauss 容器
# ------------------------------------------------------------------------------
# true  — 同时部署 openGauss + OpenViking + OpenClaw（推荐首次使用）
#          需通过 -password 参数指定 openGauss 密码
# false — 仅部署 OpenViking + OpenClaw，不启动 openGauss
#          OpenViking 将使用本地向量数据库
# ==============================================================================
ENABLE_OPENGAUSS="true"

# ==============================================================================
# [必填] 宿主机 IP 地址
# ------------------------------------------------------------------------------
# 容器间互相访问时所用的宿主机地址。
# - 同一台机器上运行，可使用 Docker 默认网关 172.17.0.1
# - 也可使用宿主机的内网 IP（如 192.168.x.x、10.x.x.x）
# - 不要使用 127.0.0.1（在容器内指向容器自身）
# ==============================================================================
HOST_IP="192.168.3.94"

# ==============================================================================
# [必填] OpenViking Root API Key
# ------------------------------------------------------------------------------
# OpenViking 服务的安全认证密钥。
# 请设置为足够复杂的随机字符串。
# ==============================================================================
OPENVIKING_ROOT_API_KEY="openviking-root-key-2026"

# ==============================================================================
# [可选] VLM（视觉语言模型）配置
# ------------------------------------------------------------------------------
# 不配置时 VLM 功能不启用。
# ==============================================================================
OPENVIKING_VLM_API_KEY="db1c7208-414a-48ca-9d18-e7ccf51f25d0"
OPENVIKING_VLM_PROVIDER="volcengine"
OPENVIKING_VLM_API_BASE="https://ark.cn-beijing.volces.com/api/coding/v3"
OPENVIKING_VLM_MODEL="doubao-seed-2-0-code-preview-260215"

# ==============================================================================
# [可选] Embedding 模型配置
# ------------------------------------------------------------------------------
# 不配置 API Key 时自动使用本地 embedding (bge-small-zh-v1.5-f16, dim=512)，
# 无需联网，开箱即用。
#
# 如需使用远程 Embedding 服务，取消注释并填写以下配置:
# ==============================================================================
# OPENVIKING_EMBEDDING_API_KEY="your_embedding_api_key"
# OPENVIKING_EMBEDDING_PROVIDER="volcengine"
# OPENVIKING_EMBEDDING_API_BASE="https://ark.cn-beijing.volces.com/api/coding/v3"
# OPENVIKING_EMBEDDING_MODEL="doubao-embedding-vision-250615"
# OPENVIKING_EMBEDDING_DIMENSION="1024"

# ==============================================================================
# [可选] 镜像 Tag（版本标签）
# ------------------------------------------------------------------------------
# 三个镜像共用此 Tag，如需分别指定可取消各服务独立 Tag 的注释。
# ==============================================================================
IMAGE_TAG="latest"

# ==============================================================================
# [可选] openGauss 镜像配置
# ==============================================================================
OG_IMAGE_REPO="opengauss/opengauss-server"
OG_IMAGE_TAG="latest"

# ==============================================================================
# [可选] OpenViking 镜像配置
# ==============================================================================
OV_IMAGE_REPO="swr.cn-north-4.myhuaweicloud.com/kunpeng-ai/openviking"
OV_IMAGE_TAG="v0.3.9-opengauss"

# ==============================================================================
# [可选] OpenClaw 镜像配置
# ==============================================================================
OC_IMAGE_REPO="swr.cn-north-4.myhuaweicloud.com/kunpeng-ai/openclaw-openviking"
OC_IMAGE_TAG="2026.4.8"

# ==============================================================================
# [可选] openGauss 参数
# ==============================================================================
# OG_HOST_PORT="15432"
# OG_CONTAINER_NAME="opengauss"
# OG_USER="gaussdb"
# OG_NODE_NAME="gaussdb"
# OG_DB_NAME="omm"
# OG_PORT="5432"
# OG_MODE="standalone"
# OG_CPUSET_CPUS=""
# OG_WAIT_TIMEOUT="120"

# ==============================================================================
# [可选] OpenViking 参数
# ==============================================================================
# OV_CONTAINER_NAME="openviking"
# OV_PORT="1933"

# ==============================================================================
# [可选] OpenClaw 参数
# ==============================================================================
# OC_CONTAINER_NAME="openclaw"
# OC_PORT="18790"
# OPENVIKING_TARGET_URI="viking://user/memories"
# OPENVIKING_AGENT_ID="main"

# OpenClaw 的 LLM 模型配置
# OPENCLAW_DEFAULT_MODEL: <provider>/<model-id> 格式
# OPENCLAW_LLM_API_KEY:   API Key（通用，不区分 provider）
# OPENCLAW_LLM_API_BASE:  API Base URL（自定义端点时使用）
#
# 脚本会根据模型名自动推断 provider，配置 openclaw.json 的完整 provider 信息
# （包括 baseUrl、api 协议、模型列表、auth-profiles.json）
#
# 同时支持 provider 专用环境变量（直传给 entrypoint）:
#   VOLCANO_ENGINE_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY, ZAI_API_KEY 等
OPENCLAW_DEFAULT_MODEL="volcengine/doubao-seed-2-0-code-preview-260215"
OPENCLAW_LLM_API_KEY="db1c7208-414a-48ca-9d18-e7ccf51f25d0"
OPENCLAW_LLM_API_BASE="https://ark.cn-beijing.volces.com/api/coding/v3"

# ==============================================================================
# [可选] 持久化目录
# ==============================================================================
# OPENCLAW_DATA_DIR="/data0/openclaw-data"
# OPENVIKING_DATA_DIR="/data0/openviking-data"

# ==============================================================================
# [可选] 其他
# ==============================================================================
# SKIP_PULL="false"
# AUTO_HEALTH_CHECK="true"
