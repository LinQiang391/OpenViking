################################################################################
# OpenClaw + OpenViking + openGauss 一键部署配置文件
# 测试配置 - 使用本地构建的镜像
################################################################################

# ==============================================================================
# 启用 openGauss
# ==============================================================================
ENABLE_OPENGAUSS="true"

# ==============================================================================
# 宿主机 IP
# ==============================================================================
HOST_IP="20.20.20.237"

# ==============================================================================
# OpenViking Root API Key
# ==============================================================================
OPENVIKING_ROOT_API_KEY="your_root_api_key"

# ==============================================================================
# VLM（视觉语言模型）配置
# ==============================================================================
OPENVIKING_VLM_API_KEY="your_vlm_api_key"
OPENVIKING_VLM_PROVIDER="volcengine"
OPENVIKING_VLM_API_BASE="https://ark.cn-beijing.volces.com/api/coding/v3"
OPENVIKING_VLM_MODEL="doubao-seed-2-0-code-preview-260215"

# ==============================================================================
# Embedding - 使用本地 embedding (bge-small-zh-v1.5-f16, dim=512)
# ==============================================================================
# 不配置 API Key，自动使用本地 embedding

# ==============================================================================
# 镜像配置 - 使用本地构建的镜像
# ==============================================================================
OG_IMAGE_REPO="opengauss"
OG_IMAGE_TAG="7.0.0-RC3"

OV_IMAGE_REPO="openviking"
OV_IMAGE_TAG="0423"

OC_IMAGE_REPO="openclaw-openviking"
OC_IMAGE_TAG="0423"

# ==============================================================================
# 容器名（避免与现有容器冲突）
# ==============================================================================
OG_CONTAINER_NAME="opengauss-test"
OV_CONTAINER_NAME="openviking-test"
OC_CONTAINER_NAME="openclaw-test"

# ==============================================================================
# 网络模式: bridge（自定义网络，容器名互访） 或 host
# ==============================================================================
DOCKER_NET_MODE="bridge"
DOCKER_NETWORK_NAME="openviking-net"

# ==============================================================================
# 端口配置（避免与现有端口冲突）
# ==============================================================================
OG_HOST_PORT="15432"
OV_PORT="1955"
OC_PORT="18799"

# ==============================================================================
# openGauss 参数 - 单机模式
# ==============================================================================
OG_USER="gaussdb"
OG_DB_NAME="omm"
OG_PORT="5432"
OG_MODE="standalone"
OG_WAIT_TIMEOUT="120"

# ==============================================================================
# OpenClaw LLM 模型配置
# ==============================================================================
OPENCLAW_DEFAULT_MODEL="volcengine/doubao-seed-2-0-code-preview-260215"
OPENCLAW_LLM_API_KEY="your_llm_api_key"
OPENCLAW_LLM_API_BASE="https://ark.cn-beijing.volces.com/api/coding/v3"

# ==============================================================================
# 跳过镜像拉取（使用本地镜像）
# ==============================================================================
SKIP_PULL="true"
