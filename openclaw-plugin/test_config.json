  },

  "paths": {
    "openclaw_home": "",
    "openviking_home": "",
    "ov_conf": "",
    "project_root": "g:\\gitcode\\clawhub\\OpenViking"
  },

  "ports": {
    "openclaw_gateway": 0,
    "openviking": 0
  },

  "profile": {
    "name": "e2e_test",
    "gateway_port": 19201,
    "gateway_token": "e2e-test-token-auto"
  },

  "models": {
    "primary": "volcengine/doubao-seed-2-0-code-preview-260215",
    "judge": "volcengine/doubao-seed-2-0-code-preview-260215",
    "provider": {
      "name": "volcengine",
      "baseUrl": "https://ark.cn-beijing.volces.com/api/coding/v3",
      "api": "openai-completions",
      "api_key": "db1c7208-414a-48ca-9d18-e7ccf51f25d0"
    }
  },

  "judge": {
    "enabled": true,
    "model": "doubao-seed-2-0-code-preview-260215",
    "base_url": "https://ark.cn-beijing.volces.com/api/coding/v3",
    "api_key": "db1c7208-414a-48ca-9d18-e7ccf51f25d0",
    "api_key_from_ov_conf": true,
    "api_key_env": "VOLCENGINE_API_KEY"
  },

  "ov_conf": {
    "server": {
      "host": "0.0.0.0",
      "root_api_key": null,
      "cors_origins": ["*"]
    },
    "storage": {
      "vectordb": {
        "name": "context",
        "backend": "local",
        "project": "default"
      },
      "agfs": {
        "backend": "local",
        "timeout": 10
      }
    },
    "embedding": {
      "dense": {
        "provider": "volcengine",
        "api_key": "db1c7208-414a-48ca-9d18-e7ccf51f25d0",
        "model": "doubao-embedding-vision-251215",
        "api_base": "https://ark.cn-beijing.volces.com/api/coding/v3",
        "dimension": 1024,
        "input": "multimodal"
      }
    },
    "vlm": {
      "provider": "volcengine",
      "api_key": "db1c7208-414a-48ca-9d18-e7ccf51f25d0",
      "model": "doubao-seed-2-0-code-preview-260215",
      "api_base": "https://ark.cn-beijing.volces.com/api/coding/v3",
      "temperature": 0.1,
      "max_retries": 3
    },
    "memory": {
      "version": "v1"
    },
    "log": {
      "level": "INFO",
      "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
      "output": "stdout"
    }
  },

  "test_data": {
    "session_messages": [
      "我叫小明，今年28岁，我是一名后端工程师，最喜欢用 Python 和 Rust 编程",
      "我最近在学习机器学习，特别是自然语言处理方向",
      "我养了一只叫「咪咪」的橘猫，已经3岁了"
    ],
    "qa_pairs": [
      {
        "question": "我叫什么名字？我是做什么工作的？",
        "expected_keywords": ["小明", "后端", "工程师"],
        "gold_answer": "你叫小明，是一名后端工程师"
      },
      {
        "question": "我最喜欢用什么编程语言？",
        "expected_keywords": ["Python", "Rust"],
        "gold_answer": "你最喜欢用 Python 和 Rust"
      },
      {
        "question": "我养的宠物叫什么？什么品种？",
        "expected_keywords": ["咪咪", "橘猫"],
        "gold_answer": "你养了一只叫咪咪的橘猫"
      }
    ]
  },

  "timeouts": {
    "command": 300,
    "gateway_start": 30,
    "ov_server_start": 60,
    "health_check": 30,
    "memory_sync_wait": 15,
    "max_retries": 3,
    "retry_delay": 5,
    "message_timeout": 120
  },

  "test_options": {
    "skip_install": false,
    "skip_cleanup": false,
    "keep_services_running": false
  }
}
